---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
---

<header class="sticky top-0 z-50 w-full border-b border-neutrals-200 bg-neutrals-50/80 backdrop-blur-md dark:border-neutrals-800 dark:bg-neutrals-950/80">
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4 sm:px-6 lg:px-8">
    
    <div class="flex items-center gap-2">
      <a href="/" class="text-xl font-heading font-bold text-neutrals-900 dark:text-neutrals-50 focus:outline-none focus:ring-2 focus:ring-primary-500 rounded-lg">
        Portfolio<span class="text-primary-500 font-bold">.</span>
      </a>
    </div>

    <!-- Actions (Language + Theme) -->
    <div class="flex items-center gap-4">
      <LanguageSwitcher />
      <ThemeToggle />
    </div>

  </div>
</header>
